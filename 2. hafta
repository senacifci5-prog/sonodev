:root {
    /* Özgün Modern Renk Paleti (Pembe teması) */
    --primary-color: #ec4899; /* Pink 500 */
    --primary-hover: #db2777; /* Pink 600 */
    --secondary-color: #f43f5e; /* Rose 500 */
    --bg-base: #1c0512; /* Çok koyu pembe-siyah */
    --bg-elevated: #280b1a; /* Koyu pembe bazlı gri */
    --bg-glass: rgba(28, 5, 18, 0.7);
    --text-main: #fdf2f8; /* Pink 50 */
    --text-muted: #fbcfe8; /* Pink 200 */
    --text-light: #fce7f3; /* Pink 100 */
    --border-color: rgba(236, 72, 153, 0.15); /* Pembe kenarlık */

    --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-normal: 0.3s cubic-bezier(0.4, 0, 0.2, 1);

    font-size: 16px;
}


/* ==========================================================================
   Reset & Base
   ========================================================================== */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
}

body {
    background-color: var(--bg-base);
    color: var(--text-main);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
}

/* ==========================================================================
   User Profile & Posts
   ========================================================================== */
.profile-modal {
    position: fixed;
    inset: 0;
    background: rgba(2, 6, 23, 0.95);
    backdrop-filter: blur(15px);
    z-index: 2500;
    overflow-y: auto;
    padding: 2rem;
    animation: fadeIn var(--transition-normal);
}

.profile-container {
    max-width: 800px;
    margin: 0 auto;
    background: var(--bg-elevated);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    padding: 2.5rem;
    position: relative;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
}

.profile-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 2rem;
}

.profile-avatar {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: bold;
    color: white;
}

.profile-info h1 {
    font-size: 2rem;
    margin-bottom: 0.2rem;
}

.profile-info p {
    color: var(--text-muted);
    font-size: 1rem;
}

.post-wrapper {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
}

.post-author {
    font-weight: 700;
    font-size: 1.1rem;
    color: #38bdf8;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.post-content {
    margin-bottom: 1.5rem;
    font-size: 1rem;
    color: var(--text-light);
}

.post-movie-attachment {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(0, 0, 0, 0.3);
    padding: 1rem;
    border-radius: 12px;
    margin-bottom: 1.5rem;
    cursor: pointer;
    transition: background 0.2s;
}

.post-movie-attachment:hover {
    background: rgba(0, 0, 0, 0.5);
}

.post-movie-attachment img {
    height: 100px;
    width: 65px;
    object-fit: cover;
    border-radius: 6px;
}

.reply-section {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 1.5rem;
}

.reply-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    animation: fadeIn 0.4s ease-out;
}

.reply-avatar {
    width: 40px;
    height: 40px;
    background: #475569;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    color: white;
    flex-shrink: 0;
}

.reply-bubble {
    background: rgba(255, 255, 255, 0.04);
    border-radius: 12px;
    padding: 1rem;
    flex: 1;
}

.reply-bubble img {
    margin-top: 0.8rem;
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.1);
}

.form-group-inline {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
}

a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-fast);
}

a:hover {
    color: var(--secondary-color);
}

ul {
    list-style: none;
}

button,
input,
textarea,
select {
    border: none;
    outline: none;
    background: none;
    font-family: inherit;
}

/* ==========================================================================
   Typography
   ========================================================================== */
h1,
h2,
h3,
h4,
h5,
h6 {
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
}

h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
}

h2 {
    font-size: 2rem;
    margin-bottom: 0.75rem;
}

h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
}

.text-muted {
    color: var(--text-muted);
}

.text-light {
    color: var(--text-light);
}

/* ==========================================================================
   Buttons
   ========================================================================== */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    /* Daha modern yuvarlak köşeler */
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all var(--transition-fast);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.btn-primary {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    color: white;
}

.btn-primary:hover {
    background: linear-gradient(135deg, var(--primary-hover), #0284c7);
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.4);
}

.btn-secondary {
    background-color: rgba(255, 255, 255, 0.1);
    color: white;
    backdrop-filter: blur(10px);
}

.btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
}

.btn-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-elevated);
    cursor: pointer;
    transition: all var(--transition-fast);
    color: white;
}

.btn-icon:hover {
    border-color: var(--secondary-color);
    color: var(--secondary-color);
    transform: scale(1.1);
}

/* ==========================================================================
   Forms & Inputs
   ========================================================================== */
.input-group {
    margin-bottom: 1.25rem;
    position: relative;
}

.input-field {
    width: 100%;
    padding: 1rem 1.25rem;
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: white;
    font-size: 1rem;
    transition: all var(--transition-fast);
}

.input-field:focus {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.3);
}

.input-field::placeholder {
    color: var(--text-muted);
}

/* ==========================================================================
   Layout & Navigation
   ========================================================================== */
.navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    padding: 1.25rem 4%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 1000;
    transition: all var(--transition-normal);
    background: transparent;
}

.navbar.scrolled {
    background-color: rgba(15, 23, 42, 0.85);
    /* Slate 900 Glassmorphism */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.nav-brand {
    font-size: 1.5rem;
    font-weight: 800;
    background: linear-gradient(to right, #f472b6, #e11d48);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.5px;
}

.nav-links {
    display: flex;
    gap: 1.5rem;
    margin-left: 3rem;
}

.nav-links a.active {
    font-weight: 700;
    color: var(--secondary-color);
    position: relative;
}

.nav-links a.active::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--secondary-color);
    border-radius: 2px;
}

.nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
}

/* ==========================================================================
   Hero Section
   ========================================================================== */
.hero {
    position: relative;
    height: 85vh;
    min-height: 600px;
    width: 100%;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, var(--bg-base) 0%, rgba(15, 23, 42, 0.4) 60%, transparent 100%),
        linear-gradient(to top, var(--bg-base) 0%, transparent 40%);
}

.hero-content {
    position: relative;
    width: 55%;
    padding-left: 4%;
    z-index: 2;
}

.hero-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    font-weight: 600;
    margin-bottom: 1.5rem;
}

.match-score {
    color: #34d399;
    /* Emerald 400 */
    background: rgba(52, 211, 153, 0.1);
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 0.85rem;
}

.rating-badge {
    border: 1px solid var(--border-color);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.85rem;
    background: rgba(255, 255, 255, 0.05);
}

.hero-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
}

/* ==========================================================================
   Movie Rows & Carousels
   ========================================================================== */
.slider-container {
    padding: 0 4%;
    margin-bottom: 4rem;
    /* Aralar açıldı */
    position: relative;
}

.slider-title {
    font-size: 1.4rem;
    margin-bottom: 1.2rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.slider-title::before {
    content: '';
    display: block;
    width: 4px;
    height: 1.2em;
    background: var(--primary-color);
    border-radius: 4px;
}

.movie-row {
    display: flex;
    gap: 1.2rem;
    /* Kartlar arası açıldı */
    overflow-x: auto;
    overflow-y: hidden;
    padding: 1rem 0 2rem 0;
    /* Hover shadow için padding artırıldı */
    scrollbar-width: none;
    scroll-behavior: smooth;
}

.movie-row::-webkit-scrollbar {
    display: none;
}

.movie-card {
    flex: 0 0 220px;
    border-radius: 12px;
    cursor: pointer;
    transition: all var(--transition-normal);
    position: relative;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.5);
    background-color: var(--bg-elevated);
}

.movie-card img {
    width: 100%;
    height: 330px;
    object-fit: cover;
    border-radius: 12px;
    transition: all var(--transition-normal);
}

.movie-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.6), 0 0 15px rgba(99, 102, 241, 0.3);
    z-index: 10;
}

/* Movie Card Info (Appears on Hover) */
.movie-card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(15, 23, 42, 1) 0%, rgba(15, 23, 42, 0.8) 50%, transparent 100%);
    padding: 2rem 1rem 1rem;
    opacity: 0;
    transition: opacity var(--transition-fast);
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
}

.movie-card:hover .movie-card-info {
    opacity: 1;
}

.movie-card-title {
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.3rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.movie-card-rating {
    font-size: 0.85rem;
    color: #fbbf24;
    /* Amber 400 */
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
}

/* Top 10 Styling */
.top-10-row {
    counter-reset: top10;
}

.top-10-card {
    display: flex;
    align-items: flex-end;
    position: relative;
    flex: 0 0 280px;
    transition: transform var(--transition-normal);
    cursor: pointer;
}

.top-10-card:hover {
    transform: translateY(-10px);
}

.top-10-card::before {
    counter-increment: top10;
    content: counter(top10);
    font-size: 12rem;
    font-weight: 800;
    line-height: 0.75;
    color: transparent;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.2);
    margin-right: -2.5rem;
    z-index: 1;
    transition: all var(--transition-normal);
}

.top-10-card:hover::before {
    color: rgba(99, 102, 241, 0.2);
    -webkit-text-stroke: 2px rgba(99, 102, 241, 0.8);
}

.top-10-card img {
    height: 280px;
    width: 186px;
    z-index: 2;
    border-radius: 8px;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
}

/* ==========================================================================
   Modals (Movie Details, Reviews)
   ========================================================================== */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.7);
    /* Siyah cam */
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
}

.modal-content {
    background-color: var(--bg-elevated);
    border-radius: 16px;
    border: 1px solid var(--border-color);
    width: 100%;
    max-width: 900px;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    animation: modalSlideUp var(--transition-normal);
}

.modal-content::-webkit-scrollbar {
    width: 8px;
}

.modal-content::-webkit-scrollbar-thumb {
    background-color: var(--primary-color);
    border-radius: 10px;
}

@keyframes modalSlideUp {
    from {
        opacity: 0;
        transform: translateY(50px) scale(0.95);
    }

    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

.modal-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.2);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 2010;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    transition: all var(--transition-fast);
}

.modal-close:hover {
    background: var(--primary-color);
    border-color: var(--primary-color);
    transform: rotate(90deg);
}

.modal-header-img {
    width: 100%;
    height: 450px;
    object-fit: cover;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 1) 50%, rgba(0, 0, 0, 0));
    -webkit-mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 1) 50%, rgba(0, 0, 0, 0));
}

.modal-body {
    padding: 0 3rem 3rem;
    margin-top: -120px;
    /* Daha fazla üst üste binsin */
    position: relative;
    z-index: 2;
}

/* Reviews Section */
.reviews-section {
    margin-top: 3rem;
    border-top: 1px solid var(--border-color);
    padding-top: 2rem;
}

.review-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
}

.review-item {
    background-color: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 1.25rem;
    border-radius: 12px;
    transition: background-color var(--transition-fast);
}

.review-item:hover {
    background-color: rgba(255, 255, 255, 0.05);
}

.review-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    align-items: center;
}

.review-author {
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.review-author::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 24px;
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    border-radius: 50%;
}

.review-form {
    background-color: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 2rem;
    border-radius: 12px;
    margin-bottom: 2rem;
}

/* ==========================================================================
   Auth Page (Tamamen Yenilendi, Özgün Tasarım)
   ========================================================================== */
.auth-page {
    height: 100vh;
    width: 100%;
    /* Abstract Gradient Background */
    background: radial-gradient(circle at top right, #831843, transparent 50%),
        radial-gradient(circle at bottom left, #881337, transparent 50%),
        var(--bg-base);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
}

/* Animasyonlu arkaplan noktaları (modern dokunuş) */
.auth-page::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.1) 1px, transparent 1px);
    background-size: 30px 30px;
    opacity: 0.5;
    z-index: 1;
}

.auth-card {
    background: rgba(30, 41, 59, 0.7);
    /* Yarı saydam Slate 800 */
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 3.5rem;
    border-radius: 24px;
    width: 100%;
    max-width: 450px;
    z-index: 2;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    text-align: center;
}

.auth-logo {
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(to right, #f472b6, #e11d48);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 2.5rem;
    letter-spacing: -1px;
}

/* Validation Msgs */
.alert-error {
    background-color: rgba(239, 68, 68, 0.1);
    border-left: 4px solid #ef4444;
    color: #fca5a5;
    padding: 1rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    text-align: left;
    font-size: 0.9rem;
}

.alert-success {
    background-color: rgba(16, 185, 129, 0.1);
    border-left: 4px solid #10b981;
    color: #6ee7b7;
    padding: 1rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    text-align: left;
    font-size: 0.9rem;
}

/* ==========================================================================
   Survey Overlay (What Should I Watch)
   ========================================================================== */
.survey-overlay {
    position: fixed;
    inset: 0;
    background: rgba(2, 6, 23, 0.95);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    z-index: 3000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    overflow-y: auto;
    padding: 4rem 1rem;
    animation: fadeIn var(--transition-normal);
}

.survey-content {
    text-align: center;
    max-width: 900px;
    width: 100%;
    padding: 2rem;
}

.survey-title {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    background: linear-gradient(to right, #a78bfa, #38bdf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: slideDown var(--transition-normal);
}

.survey-subtitle {
    font-size: 1.2rem;
    color: var(--text-light);
    margin-bottom: 3rem;
    animation: fadeIn var(--transition-normal) 0.3s forwards;
    opacity: 0;
}

.survey-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
    animation: fadeIn var(--transition-normal) 0.5s forwards;
    opacity: 0;
}

.survey-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: 20px;
    padding: 2.5rem 1.5rem;
    cursor: pointer;
    transition: all var(--transition-normal);
    position: relative;
    overflow: hidden;
}

.survey-card:hover {
    transform: translateY(-8px);
    background: rgba(139, 92, 246, 0.15);
    border-color: #a78bfa;
    box-shadow: 0 15px 30px -5px rgba(139, 92, 246, 0.4);
}

.survey-card i {
    font-size: 3.5rem;
    margin-bottom: 1.5rem;
    color: var(--secondary-color);
    transition: transform var(--transition-normal);
}

.survey-card:hover i {
    transform: scale(1.1) rotate(5deg);
    color: #a78bfa;
}

.survey-card h3 {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
}

.magic-loader {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
}

.magic-spinner {
    font-size: 5rem;
    background: linear-gradient(to right, #a78bfa, #38bdf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: spin 2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }

    to {
        opacity: 1;
    }
}

@keyframes slideDown {
    from {
        transform: translateY(-40px);
        opacity: 0;
    }

    to {
        transform: translateY(0);
        opacity: 1;
    }
}

@keyframes spin {
    100% {
        transform: rotate(360deg);
    }
}

